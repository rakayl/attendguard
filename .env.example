# ── Server ──────────────────────────────────────────────────
API_PORT=8080
WEB_PORT=3000
GIN_MODE=release

# ── Database ─────────────────────────────────────────────────
DB_USER=postgres
DB_PASS=supersecretpassword
DB_NAME=attendance_db
DB_PORT=5432

# ── Auth ─────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=change-this-to-a-64-char-random-secret-in-production!!

# ── Office Location (fallback circle geofence) ────────────────
# These are used as the center of the default geofence seed zone.
# Update to your actual office coordinates.
OFFICE_LAT=-6.200000
OFFICE_LONG=106.816666
GEOFENCE_RADIUS=200
